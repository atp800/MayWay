---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/ui/Hero.astro';
import backgroundImage from '../../assets/moalboal_drone_2.webp';
// import backgroundImage from '../../assets/pexels-1320686.jpeg';
---

<BaseLayout title="Home | MAYWAY Travels">
  
  <!-- We pass the Dutch text as props to the reusable Hero component -->
  <Hero 
    heroImage={backgroundImage}
    titleLine1="Your adventure,"
    titleLine2="YOUR WAY"
    subtitle="Personal travel experiences & custom routes"
    primaryButtonText="Plan your trip"
    primaryButtonLink="/en/contact"
    secondaryButtonText="View e-guides"
    secondaryButtonLink="/en/e-guides"
  />

  <!-- The next sections (Hotspots, About Mayra, etc.) will go here! -->

</BaseLayout>