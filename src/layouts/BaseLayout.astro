---
import '../styles/global.css';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';

const { title = "MAYWAY TRAVELS" } = Astro.props;
---

<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <!-- FONTS  -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat+Brush&family=Neucha&family=Zain&display=swap" rel="stylesheet">


  </head>
  <body class="bg-[#FFFDFA] text-gray-900 font-sans antialiased min-h-screen flex flex-col">
    
    <Header />

    <!-- main tag ensures the content takes up the remaining space -->
    <main class="flex-grow">
      <slot /> 
    </main>

    <Footer />

  </body>
</html>