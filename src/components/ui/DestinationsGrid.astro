---
import { ui, defaultLang } from '../../i18n/ui';

const lang = Astro.currentLocale || defaultLang;

function t(key: keyof typeof ui[typeof defaultLang]) {
  return ui[lang as keyof typeof ui][key];
}

export interface Props {
  destinations: {
    id: string;
    name: string;
    desc: string;
    img: string;
  }[];
}

const { destinations } = Astro.props;
---

<div class="w-full max-w-6xl mx-auto px-6 py-12">
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 lg:gap-8">
    
    {destinations.map((dest) => (
      /* Added 'dest-card' class so JS can target it */
      <div class="dest-card group relative w-full aspect-[4/5] rounded-3xl overflow-hidden shadow-lg cursor-pointer bg-gray-900">
        
        <!-- Background Image (Changed group-hover to group-[.is-active]) -->
        <img 
          src={dest.img} 
          alt={dest.name} 
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-[.is-active]:scale-110 opacity-90 group-[.is-active]:opacity-100" 
        />
        
        <!-- Dark Gradient Overlay (Changed group-hover to group-[.is-active]) -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent transition-all duration-500 group-[.is-active]:from-black/95 group-[.is-active]:via-black/60 group-[.is-active]:to-black/20"></div>
        
        <!-- Content Container -->
        <div class="absolute inset-0 p-6 md:p-8 flex flex-col justify-end">
          
          <!-- Title (Changed group-hover to group-[.is-active]) -->
          <h3 class="text-3xl font-bold text-white font-libre tracking-wide drop-shadow-md mb-0 group-[.is-active]:mb-3 transition-all duration-300">
            {dest.name}
          </h3>
          
          <!-- Hover Reveal (Changed group-hover to group-[.is-active]) -->
          <div class="grid grid-rows-[0fr] group-[.is-active]:grid-rows-[1fr] transition-[grid-template-rows] duration-500 ease-in-out">
            <div class="overflow-hidden">
              <div class="pt-1 opacity-0 group-[.is-active]:opacity-100 transition-opacity duration-500 delay-100 flex flex-col gap-4">
                
                <p class="text-gray-200 text-sm md:text-base leading-relaxed line-clamp-4">
                  {dest.desc}
                </p>
                
                <a 
                  href={`/${lang}/contact`} 
                  class="mt-2 block w-full text-center bg-[#4ED2CE] hover:bg-[#1CABB0] text-white py-3.5 rounded-xl font-bold shadow-md transition-colors"
                >
                  {t('destinations.btn')}
                </a>
                
              </div>
            </div>
          </div>

        </div>
      </div>
    ))}

  </div>
</div>

<script>
  function initGridInteraction() {
    const cards = document.querySelectorAll('.dest-card');
    let activeCard: Element | null = null;

    function closeActive() {
      if (activeCard) {
        activeCard.classList.remove('is-active');
        activeCard = null;
      }
    }

    function openCard(card: Element) {
      if (activeCard === card) return;
      closeActive(); // Closes any previously opened card
      card.classList.add('is-active');
      activeCard = card;
    }

    cards.forEach(card => {
      // Desktop Hover behavior
      card.addEventListener('mouseenter', () => openCard(card));
      card.addEventListener('mouseleave', () => closeActive());

      // Mobile Tap/Click behavior
      card.addEventListener('click', (e) => {
        e.stopPropagation();
        
        // Let the button click register normally so it navigates to the contact page
        if ((e.target as HTMLElement).closest('a')) return;
        
        openCard(card);
      });
    });

    // Close when tapping anywhere else on the page
    document.removeEventListener('click', closeActive);
    document.addEventListener('click', closeActive);
  }

  initGridInteraction();

  // Support for Astro View Transitions (if used in your project)
  document.addEventListener('astro:after-swap', initGridInteraction);
</script>