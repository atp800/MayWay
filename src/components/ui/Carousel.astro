---
import { useTranslations } from '../../i18n/ui';

// Detect language
// Astro.currentLocale works if you configured i18n in astro.config.mjs.
// The fallback checks if the URL starts with /en/
type SupportedLang = 'nl' | 'en';
const currentPath = Astro.url.pathname;
const lang = (Astro.currentLocale || (currentPath.startsWith('/en') ? 'en' : 'nl')) as SupportedLang;
const t = useTranslations(lang);

const slides = [
  { 
    title: { nl: "Great Ocean Road", en: "Great Ocean Road" }, 
    image: "/images/pexels-31980293.jpeg", 
    link: { nl: "/e-gidsen", en: "/en/e-guides" } 
  },
  { 
    title: { nl: "Sydney & NSW", en: "Sydney & NSW" }, 
    image: "/images/pexels-5066013.jpeg", 
    link: { nl: "/e-gidsen", en: "/en/e-guides" } 
  },
 { 
    title: { nl: "Queensland & Rif", en: "Queensland & Rife" }, 
    image: "/images/pexels-15763636.jpeg", 
    link: { nl: "/e-gidsen", en: "/en/e-guides" } 
  },
{ 
    title: { nl: "Uluru & Red Centre", en: "Uluru & Red Centre" }, 
    image: "/images/pexels-35890005.jpeg", 
    link: { nl: "/e-gidsen", en: "/en/e-guides" } 
  },
  { 
    title: { nl: "Tasmanië", en: "Tasmania" }, 
    image: "/images/pexels-988946.jpeg", 
    link: { nl: "/e-gidsen", en: "/en/e-guides" } 
  },
  { 
    title: { nl: "West-Australië", en: "Western Australia" }, 
    image: "/images/pexels-5775290.jpeg", 
    link: { nl: "/e-gidsen", en: "/en/e-guides" } 
  },
  { 
    title: { nl: "Nieuw-Zeeland", en: "New Zealand" }, 
    image: "/images/pexels-4784435.jpeg", 
    link: { nl: "/e-gidsen", en: "/en/e-guides" } 
  },
  { 
    title: { nl: "Bali & Indonesië", en: "Bali & Indonesia" }, 
    image: "/images/pexels-3601456.jpeg", 
    link: { nl: "/e-gidsen", en: "/en/e-guides" } 
  }
];
---


<section class="py-24 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-8 mb-12">
      <h2 class="max-w-xl">
        <span class="block font-bold text-3xl md:text-5xl text-gray-800 font-neucha">{t('carousel.subtitle')}</span>
        <span class="block text-3xl md:text-4xl text-[#4ED2CE] mt-1 leading-tight">{t('carousel.title')}</span>
      </h2>
      <p class="lg:max-w-md lg:text-right text-lg text-gray-600 leading-relaxed lg:pt-2">
        {t('carousel.desc')}
      </p>
    </div>

    <!-- Carousel Track -->
    <div id="carousel-track" class="flex gap-6 overflow-x-auto snap-x snap-proximity pb-2 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden smooth-scroll">
      {slides.map((slide) => (
        <article class="relative flex-shrink-0 w-[min(85vw,20rem)] md:w-[280px] lg:w-[300px] snap-start rounded-3xl overflow-hidden shadow-lg h-[420px]">
          <img src={slide.image} alt={slide.title[lang]} class="absolute inset-0 w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/25 to-transparent"></div>
          <div class="absolute inset-0 flex flex-col justify-end">
            <div class="px-5 pb-5 text-center">
              <p class="text-[11px] uppercase tracking-[0.2em] text-white/90 mb-2">{t('carousel.badge')}</p>
              
              <!-- Select the correct language from the slide object -->
              <h3 class="text-2xl font-bold text-white mb-4">{slide.title[lang]}</h3>
              
              <a class="inline-flex items-center gap-2 rounded-full border-2 border-white px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-white/15" href={slide.link[lang]}>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-smartphone"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect><path d="M12 18h.01"></path></svg>
                {t('carousel.btn')}
              </a>
            </div>
            <div class="bg-[#1CABB0] py-2.5 px-3 text-center">
              <p class="text-[10px] sm:text-xs uppercase tracking-wide text-white font-medium leading-snug">
                {t('carousel.features')}
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Controls -->
    <div class="flex items-center justify-center gap-6 mt-8">
      <button 
        id="carousel-prev" 
        type="button" 
        disabled 
        class="p-2 rounded-full text-[#4ED2CE] hover:bg-[#E6F6F6] disabled:opacity-30 disabled:hover:bg-transparent transition-colors" 
        aria-label="Vorige"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left"><path d="m15 18-6-6 6-6"></path></svg>
      </button>
      
      <div class="flex gap-2" id="carousel-dots">
        {slides.map((_, index) => (
          <button 
            type="button" 
            class={`carousel-dot h-2.5 rounded-full transition-all ${index === 0 ? 'w-8 bg-[#4ED2CE]' : 'w-2.5 bg-gray-300 hover:bg-gray-400'}`}
            aria-label={`Ga naar slide ${index + 1}`}
            data-index={index}
          ></button>
        ))}
      </div>

      <button 
        id="carousel-next" 
        type="button" 
        class="p-2 rounded-full text-[#4ED2CE] hover:bg-[#E6F6F6] disabled:opacity-30 disabled:hover:bg-transparent transition-colors" 
        aria-label="Volgende"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right"><path d="m9 18 6-6-6-6"></path></svg>
      </button>
    </div>
  </div>
</section>

<style>
  /* Optional: Ensures smooth scrolling behavior specifically for the track */
  .smooth-scroll {
    scroll-behavior: smooth;
  }
</style>

<script>
  function initCarousel() {
    const track = document.getElementById('carousel-track');
    const prevBtn = document.getElementById('carousel-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('carousel-next') as HTMLButtonElement;
    const dots = document.querySelectorAll('.carousel-dot');

    if (!track || !prevBtn || !nextBtn) return;

    // The gap in pixels defined in your tailwind class (gap-6 = 1.5rem = 24px)
    const gap = 24; 

    const updateControls = () => {
      if (!track.firstElementChild) return;
      
      const scrollLeft = track.scrollLeft;
      const maxScroll = track.scrollWidth - track.clientWidth;
      const itemWidth = (track.firstElementChild as HTMLElement).offsetWidth + gap;
      
      // Update Buttons
      prevBtn.disabled = scrollLeft <= 0;
      nextBtn.disabled = scrollLeft >= maxScroll - 1; // -1 to account for sub-pixel rounding

      // Update Dots
      const activeIndex = Math.round(scrollLeft / itemWidth);
      
      dots.forEach((dot, index) => {
        if (index === activeIndex) {
          dot.classList.replace('w-2.5', 'w-8');
          dot.classList.replace('bg-gray-300', 'bg-[#4ED2CE]');
          dot.classList.remove('hover:bg-gray-400');
        } else {
          dot.classList.replace('w-8', 'w-2.5');
          dot.classList.replace('bg-[#4ED2CE]', 'bg-gray-300');
          dot.classList.add('hover:bg-gray-400');
        }
      });
    };

    const scrollToIndex = (index: number) => {
      if (!track.firstElementChild) return;
      const itemWidth = (track.firstElementChild as HTMLElement).offsetWidth + gap;
      track.scrollTo({ left: index * itemWidth, behavior: 'smooth' });
    };

    // Event Listeners
    prevBtn.addEventListener('click', () => {
      if (!track.firstElementChild) return;
      const itemWidth = (track.firstElementChild as HTMLElement).offsetWidth + gap;
      track.scrollBy({ left: -itemWidth, behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      if (!track.firstElementChild) return;
      const itemWidth = (track.firstElementChild as HTMLElement).offsetWidth + gap;
      track.scrollBy({ left: itemWidth, behavior: 'smooth' });
    });

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => scrollToIndex(index));
    });

    track.addEventListener('scroll', updateControls, { passive: true });
    window.addEventListener('resize', updateControls);

    // Initial check
    updateControls();
  }

  // Support Astro ViewTransitions if you are using them
  document.addEventListener('astro:page-load', initCarousel);
  
  // Also run on standard load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousel);
  } else {
    initCarousel();
  }
</script>