---
import { Image } from 'astro:assets';
import hero from '../../assets/moalboal_drone_2.webp';

const { title, title2, subtitle } = Astro.props;
---

<section class="hero">
  <Image
    src={hero}
    alt=""
    widths={[800, 1200, 1600, 2000]}
    sizes="100vw"
    class="bg"
  />

  <div class="overlay"></div>

  <div class="content">
    <h1 class="hero-title">{title}</h1>
    <h2 class="hero-title-2">{title2}</h2>
    <p class="hero-subtitle">{subtitle}</p>
  </div>
</section>

<style>
.hero {
  position: relative;
  height: 100vh;
  overflow: hidden;
}

.bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0);
}

.content {
  position: relative;
  z-index: 2;
  text-align: center;
  top: 50%;
  transform: translateY(-100%);
  color: white;
}

.hero-title {
  font-size: 4rem;      /* really big */
  font-weight: 900;     /* bold */
  margin: 0;
}

.hero-title-2 {
  font-size: 4.5rem;      /* really big */
  font-weight: 700;     /* bold */
  margin: -1.5rem 0 0; /* pull it up a bit */
  color: aquamarine;
  font-style: italic;
}

.hero-subtitle {
  font-size: 1.5rem;
  margin-top: 1rem;
  font-weight: 500;
}
</style>
